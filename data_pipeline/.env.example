# ============================================================================
# Samla Digital — Ad Platform Credentials
# Copy this file to `.env` (same folder) and fill in your real values.
# Never commit `.env` to git. The fetcher reads from `.env` only.
# ============================================================================

# ----- Google Ads ------------------------------------------------------------
# Apply for a developer token at https://ads.google.com/aw/apicenter
# OAuth: use the Google Ads OAuth Playground or scripts/oauth_google.py to mint a refresh token
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=     # MCC id (digits only, no dashes), optional
GOOGLE_ADS_CUSTOMER_ID=           # account id you want to pull (digits only)

# ----- Meta (Facebook + Instagram) Ads --------------------------------------
# Use a System User token from Business Manager → System Users → Generate Token
# Required scopes: ads_read, business_management
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=               # format: act_1234567890

# ----- LinkedIn Ads ----------------------------------------------------------
# Create a LinkedIn Marketing Developer Platform app, then OAuth a user with rw_ads/r_ads_reporting
# Tokens expire after 60 days — refresh via scripts/oauth_linkedin.py
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=           # numeric, e.g. 503012345

# ----- TikTok Ads ------------------------------------------------------------
# Create a TikTok for Business app, OAuth in, get long-lived access token
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ----- Snapchat Ads ----------------------------------------------------------
# Create an OAuth app in Snap Business Manager. Use it to mint a refresh token.
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REFRESH_TOKEN=
SNAPCHAT_AD_ACCOUNT_ID=

# ----- Steam -----------------------------------------------------------------
# App ID is public (visible in store URL). Web API key is optional —
# without it, the fetcher pulls public data only (name, release, current players, reviews).
# With it, more endpoints unlock. Wishlist count requires a Steamworks PARTNER
# key, not the public Web API key — leave STEAM_PARTNER_API_KEY blank if you
# don't have partner access.
STEAM_APP_ID=3988870
STEAM_WEB_API_KEY=
STEAM_PARTNER_API_KEY=

# ----- Output ----------------------------------------------------------------
# Where the fetcher writes the consolidated JSON the dashboard reads.
# It also writes live_data.js next to it (a small JS wrapper around the JSON)
# so HTML dashboards opened via file:// can pick it up via <script src=...>.
OUTPUT_PATH=./live_data.json
JS_OUTPUT_PATH=./live_data.js
LOG_PATH=./fetch.log
